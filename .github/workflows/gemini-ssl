name: Build ijkplayer with OpenSSL (Fast - armv7a + arm64)

on:
  # 手动触发，方便调试和选择性编译
  workflow_dispatch:
    inputs:
      build_config:
        description: 'Build configuration'
        required: true
        default: 'module-default.sh' # 使用module-default.sh作为默认，并进行修改
        type: choice
        options:
          - module-lite.sh
          - module-default.sh
          - module-lite-hevc.sh
      architectures:
        description: 'Target architectures (all or specific)'
        required: true
        default: 'armv7a arm64' # 默认只编译armv7a和arm64以加速
        type: string # 改为string，允许输入多个架构

jobs:
  build:
    runs-on: ubuntu-22.04  # 更新为 Ubuntu 22.04
    timeout-minutes: 150   # 适当增加超时时间，以防万一

    env:
      ANDROID_SDK_ROOT: /opt/android-sdk
      ANDROID_NDK_HOME: /opt/android-ndk-r14b # 明确指定 NDK r14b
      IJK_VERSION: k0.8.8 # 明确指定ijkplayer版本
      BUILD_ARCHITECTURES: ${{ github.event.inputs.architectures || 'armv7a arm64' }} # 从输入获取或使用默认值

    steps:
      # 1. 检出代码
      - name: Checkout repository
        uses: actions/checkout@v4

      # 2. 缓存 Android SDK 和 NDK
      # 第一次运行会下载，后续运行会大大加速
      - name: Cache Android SDK and NDK
        id: cache-android
        uses: actions/cache@v4
        with:
          path: |
            /opt/android-sdk
            /opt/android-ndk-r14b # 更新缓存路径
          key: ${{ runner.os }}-android-sdk-ndk-r14b-v3 # 更改版本以在更新缓存策略后重新生成

      # 3. 安装依赖工具 (如果缓存未命中或NDK/SDK需要更新)
      - name: Install dependencies and Python2.7
        if: steps.cache-android.outputs.cache-hit != 'true'
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            git yasm curl wget gcc g++ pkg-config autoconf automake libtool \
            cmake unzip build-essential openjdk-8-jdk libncurses5 \
            libstdc++6 file bc software-properties-common

          # 关键：安装 Python2.7。Ubuntu 22.04 默认不提供，需要通过 deadsnakes PPA
          sudo add-apt-repository -y ppa:deadsnakes/ppa
          sudo apt-get update
          sudo apt-get install -y python2.7

          # 确保 python 命令指向 python2.7
          sudo update-alternatives --install /usr/bin/python python /usr/bin/python2.7 1
          python --version
          
          # 设置 JAVA_HOME
          echo "JAVA_HOME=$(update-java-alternatives -l | grep "java-1.8" | awk '{print $NF}')" >> $GITHUB_ENV
          echo "Current JAVA_HOME: $JAVA_HOME"


      # 4. 下载并配置Android SDK (如果缓存未命中)
      - name: Setup Android SDK
        if: steps.cache-android.outputs.cache-hit != 'true'
        run: |
          sudo mkdir -p $ANDROID_SDK_ROOT
          cd $ANDROID_SDK_ROOT

          # 下载命令行工具 (可能需要最新版本来管理较旧的SDK)
          sudo wget -q https://dl.google.com/android/repository/commandlinetools-linux-7583922_latest.zip
          sudo unzip -q commandlinetools-linux-7583922_latest.zip
          sudo mkdir -p cmdline-tools/latest
          sudo mv cmdline-tools/* cmdline-tools/latest/ 2>/dev/null || true

          # 安装必要的SDK组件 (ijkplayer k0.8.8 兼容的版本)
          yes | sudo cmdline-tools/latest/bin/sdkmanager --licenses || true
          sudo cmdline-tools/latest/bin/sdkmanager "platforms;android-21" # ijkplayer k0.8.8 官方推荐或兼容版本
          sudo cmdline-tools/latest/bin/sdkmanager "build-tools;25.0.3" # ijkplayer k0.8.8 兼容
          sudo cmdline-tools/latest/bin/sdkmanager "platform-tools"

          echo "$ANDROID_SDK_ROOT/platform-tools" >> $GITHUB_PATH # 添加platform-tools到PATH

      # 5. 下载NDK r14b （与ijkplayer k0.8.8 和 Ubuntu 22.04 兼容的较好版本） (如果缓存未命中)
      - name: Download Android NDK r14b
        if: steps.cache-android.outputs.cache-hit != 'true'
        run: |
          sudo mkdir -p /opt
          cd /opt
          # 使用国内镜像加速下载，增加稳定性
          sudo wget -q https://dl.google.com/android/repository/android-ndk-r14b-linux-x86_64.zip || \
          sudo wget -q https://mirrors.tuna.tsinghua.edu.cn/android/repository/android-ndk-r14b-linux-x86_64.zip

          sudo unzip -q android-ndk-r14b-linux-x86_64.zip
          sudo rm android-ndk-r14b-linux-x86_64.zip

          # 关键：修复NDK中的awk问题，避免冲突 (仍然可能存在)
          if [ -f "$ANDROID_NDK_HOME/prebuilt/linux-x86_64/bin/awk" ]; then
            sudo rm -f $ANDROID_NDK_HOME/prebuilt/linux-x86_64/bin/awk
          fi
          
          # 将NDK添加到PATH
          echo "$ANDROID_NDK_HOME" >> $GITHUB_PATH

      # 6. 克隆ijkplayer源码
      - name: Clone ijkplayer source
        run: |
          git clone https://github.com/Bilibili/ijkplayer.git ijkplayer-android
          cd ijkplayer-android
          git checkout -B latest $IJK_VERSION
          git log --oneline -1 # 显示当前版本

      # 7. 配置编译选项 (核心修复步骤)
      - name: Configure build options (Critical Fix)
        run: |
          cd /home/runner/ijkplayer-android/config

          # 移除旧的module.sh
          rm -f module.sh
          
          # 关键：复制而不是软链接，这样我们可以安全修改文件内容
          cp ${{ github.event.inputs.build_config || 'module-default.sh' }} module.sh

          # 关键修改1：必须注释掉这两行 (FFmpeg 4.0+ 已删除ffserver和vda)
          sed -i 's/^export COMMON_FF_CFG_FLAGS="$COMMON_FF_CFG_FLAGS --disable-ffserver"/# &/' module.sh
          sed -i 's/^export COMMON_FF_CFG_FLAGS="$COMMON_FF_CFG_FLAGS --disable-vda"/# &/' module.sh

          # 关键修改2：在文件末尾追加禁用linux-perf和启用openssl
          # 这样可以确保这些标志在任何原有配置之后生效
          cat >> module.sh << 'EOF'

# Fix: Disable linux-perf to avoid missing perf_event.h
export COMMON_FF_CFG_FLAGS="$COMMON_FF_CFG_FLAGS --disable-linux-perf"

# Enable OpenSSL for HTTPS support
export COMMON_FF_CFG_FLAGS="$COMMON_FF_CFG_FLAGS --enable-openssl"
EOF
          
          echo "=== Final module.sh content ==="
          cat module.sh # 输出最终配置供调试检查

      # 8. 初始化OpenSSL和FFmpeg源码
      - name: Initialize OpenSSL and FFmpeg
        run: |
          cd /home/runner/ijkplayer-android
          # 显式使用bash执行，避免dash shell的语法问题
          bash ./init-android.sh
          bash ./init-android-openssl.sh

      # 9. 编译OpenSSL
      - name: Compile OpenSSL
        run: |
          cd /home/runner/ijkplayer-android/android/contrib
          ./compile-openssl.sh clean
          echo "Compiling OpenSSL for architectures: $BUILD_ARCHITECTURES"
          for arch in $BUILD_ARCHITECTURES; do
            ./compile-openssl.sh $arch
          done

      # 10. 编译FFmpeg
      - name: Compile FFmpeg
        run: |
          cd /home/runner/ijkplayer-android/android/contrib
          ./compile-ffmpeg.sh clean
          echo "Compiling FFmpeg for architectures: $BUILD_ARCHITECTURES"
          for arch in $BUILD_ARCHITECTURES; do
            ./compile-ffmpeg.sh $arch
          done

      # 11. 编译ijkplayer生成SO文件
      - name: Compile ijkplayer SO libraries
        run: |
          cd /home/runner/ijkplayer-android/android
          ./compile-ijk.sh clean 2>/dev/null || true
          echo "Compiling ijkplayer for architectures: $BUILD_ARCHITECTURES"
          for arch in $BUILD_ARCHITECTURES; do
            ./compile-ijk.sh $arch
          done

      # 12. 验证编译结果并收集SO文件
      - name: Verify and Collect SO files
        run: |
          cd /home/runner/ijkplayer-android/android/ijkplayer
          mkdir -p /home/runner/output/so-libraries

          # 遍历并复制SO文件，根据构建架构动态调整
          for arch_type in $BUILD_ARCHITECTURES; do
            ARCH_DIR=""
            case "$arch_type" in
              armv7a) ARCH_DIR="armeabi-v7a" ;;
              arm64)  ARCH_DIR="arm64-v8a" ;;
              x86)    ARCH_DIR="x86" ;;
              x86_64) ARCH_DIR="x86_64" ;;
              *)      echo "Unknown architecture: $arch_type, skipping." && continue ;;
            esac
            
            SOURCE_LIBS_PATH="ijkplayer-$arch_type/src/main/libs/$ARCH_DIR"
            DEST_LIBS_PATH="/home/runner/output/so-libraries/$ARCH_DIR"

            if [ -d "$SOURCE_LIBS_PATH" ]; then
              mkdir -p "$DEST_LIBS_PATH"
              cp "$SOURCE_LIBS_PATH"/*.so "$DEST_LIBS_PATH/"
              echo "Copied SO files for $ARCH_DIR:"
              ls -lh "$DEST_LIBS_PATH/"
              
              # 关键：验证libijkffmpeg.so是否包含OpenSSL符号
              echo "=== Checking OpenSSL symbols in $DEST_LIBS_PATH/libijkffmpeg.so ==="
              if [ -f "$DEST_LIBS_PATH/libijkffmpeg.so" ]; then
                if nm -D "$DEST_LIBS_PATH/libijkffmpeg.so" 2>/dev/null | grep -i -E "ssl|tls|https" | head -10; then
                  echo "✓ $DEST_LIBS_PATH/libijkffmpeg.so contains SSL/OpenSSL symbols."
                else
                  echo "✗ WARNING: $DEST_LIBS_PATH/libijkffmpeg.so MAY NOT contain SSL/OpenSSL symbols."
                fi
              else
                echo "✗ ERROR: $DEST_LIBS_PATH/libijkffmpeg.so not found!"
              fi
            else
              echo "WARNING: Source directory not found for $ARCH_DIR: $SOURCE_LIBS_PATH"
            fi
          done

          # 创建README文件
          cat > /home/runner/output/README.txt << EOF
ijkplayer with OpenSSL (HTTPS Support)
=======================================

Build Date: $(date)
ijkplayer Version: $IJK_VERSION
NDK Version: r14b
Configuration: ${{ github.event.inputs.build_config || 'module-default.sh' }}
Architectures: $BUILD_ARCHITECTURES

SO Files Location:
- so-libraries/armeabi-v7a/  - ARM 32位
- so-libraries/arm64-v8a/    - ARM 64位
- so-libraries/x86/          - x86 32位 (如果编译)
- so-libraries/x86_64/       - x86 64位 (如果编译)

Each architecture contains:
- libijkffmpeg.so  (FFmpeg + OpenSSL)
- libijkplayer.so  (ijkplayer core)
- libijksdl.so     (SDL for audio/video output)

Usage:
1. Copy the SO files for your target architecture to app/src/main/jniLibs/
2. In your app/build.gradle, ensure you have the ijkplayer-java dependency.
3. Set protocol whitelist before playing:
   player.setOption(IjkMediaPlayer.OPT_CATEGORY_FORMAT, "protocol_whitelist", 
       "async,cache,crypto,file,http,https,ijkhttphook,...");

EOF
          echo "=== Final output structure ==="
          tree /home/runner/output/ || find /home/runner/output/ -type f

      # 13. 上传构建产物
      - name: Upload build artifacts
        uses: actions/upload-artifact@v4
        with:
          name: ijkplayer-openssl-libs-${{ github.run_number }}
          path: /home/runner/output/
          retention-days: 30
